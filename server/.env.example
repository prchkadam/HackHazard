# Avati Express Server Environment Variables Example
# Duplicate this file as '.env' and fill in correct values.

# Port for Express server to listen on
PORT=5000

# Secret key used for signing & verifying JWT Authentication tokens
JWT_SECRET=super_secret_session_key_do_not_share

# Neo4j AuraDB Connection Configs
NEO4J_URI=neo4j+s://xxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password

# Gemini Pro API Key (Obtain from Google AI Studio)
GEMINI_API_KEY=AIzaSyYourGeminiApiKeyHere
